# Copy this file to .env and fill in the values. Never commit .env to git.

# LLMapi key — OpenAI-compatible proxy for Claude and other models
# Get one at https://llmapi.ai
LLMAPI_KEY=your_llmapi_key_here
LLMAPI_BASE_URL=https://api.llmapi.ai/v1

# --- Local dev: SQLite ---
# Path to the SQLite database file. Used when DATABASE_URL is not set.
DATABASE_PATH=analyses.db

# --- Production (Vercel): Postgres ---
# When set to a postgres:// or postgresql:// URL, cache.py switches to Postgres.
# On Vercel this is auto-provisioned by the Neon integration — do not set it locally
# unless you want to test against a real Postgres.
# DATABASE_URL=postgresql://user:pass@host/db

# Backend server port (local only; ignored on Vercel)
PORT=8000
