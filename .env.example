# Copy this file to .env and fill in the values. Never commit .env to git.

# LLMapi key — OpenAI-compatible proxy for Claude and other models
# Get one at https://llmapi.ai
LLMAPI_KEY=your_llmapi_key_here
LLMAPI_BASE_URL=https://api.llmapi.ai/v1

# Path to the SQLite database file (dev). Switch to a postgres:// URL in production.
DATABASE_PATH=analyses.db

# Backend server port
PORT=8000
